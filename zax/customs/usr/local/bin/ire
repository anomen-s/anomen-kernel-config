#!/bin/bash

# Interactive rename

filename="$1"

if [ -z "${filename}" ]
then
 echo missing filename
 exit 1
fi

if [[ "$filename" == *.* && "$filename" != .* ]]; then
    filename_no_ext="${filename%.*}"
else
    filename_no_ext="$filename"
fi

if [[ "$filename" == *.* && "$filename" != .* ]]
then
    extension="${filename##*.}"
else
  echo "No extension !"
  exit 1
fi

echo "File:              $filename"
echo "Filename w/o ext.: $filename_no_ext"
echo "File extension:    $extension"

if which rlwrap > /dev/null
then
 N=$(rlwrap -pYellow -S 'New extension:     '  -P "${extension}" -o cat)
else
 echo 'New extension:     '
 read N
fi

# If user cancels the operation, exit
if [ $? -ne 0 ]; then
    exit $?
fi

if [ -z "$N" ]
then
 echo "No extension given"
 exit 1
fi

NN="${filename_no_ext}.${N}"

if [ "x$NN" = "x$filename" ]
then
 echo "No change in extension."
 exit 0
fi

if [ -e "$NN" ]
then
 echo "File already exists !"
 exit 0
fi

mv -n -v "$filename" "$NN"
